PAPERCLIP_API_URL=http://127.0.0.1:3100
PAPERCLIP_API_KEY=paperclip_agent_or_board_api_key
PAPERCLIP_COMPANY_ID=00000000-0000-0000-0000-000000000000
PAPERCLIP_AGENT_ID=00000000-0000-0000-0000-000000000000
PAPERCLIP_RUN_ID=

# Set this in the repo root environment when you want `pnpm dev` to manage the
# MCP HTTP process as a sidecar.
PAPERCLIP_MCP_ENABLED=false

# read_only exposes only read tools. Use read_write only after the ChatGPT agent
# approval policy and audit path are ready.
PAPERCLIP_MCP_ACCESS_MODE=read_only
PAPERCLIP_MCP_API_TIMEOUT_MS=5000

# Keep the generic /api escape hatch disabled for ChatGPT. Dedicated write tools
# are exposed in read_write mode without this.
PAPERCLIP_MCP_ENABLE_API_REQUEST_TOOL=false

# HTTP transport for remote MCP clients.
PAPERCLIP_MCP_HTTP_HOST=127.0.0.1
PAPERCLIP_MCP_HTTP_PORT=8787
PAPERCLIP_MCP_HTTP_PATH=/mcp
PAPERCLIP_MCP_MAX_CONCURRENT_REQUESTS=4
PAPERCLIP_MCP_RATE_LIMIT_WINDOW_MS=60000
PAPERCLIP_MCP_RATE_LIMIT_MAX_REQUESTS=60
PAPERCLIP_MCP_MAX_REQUEST_BODY_BYTES=1048576

# Required when binding to a non-loopback host unless another trusted layer
# handles authentication.
PAPERCLIP_MCP_BEARER_TOKEN=
PAPERCLIP_MCP_ALLOW_UNAUTHENTICATED_HTTP=false
